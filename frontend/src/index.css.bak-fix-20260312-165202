  animation: introFaceBlink 4.5s ease-in-out 2.6s infinite;
}

.network-layer{
  transition: opacity .7s ease;
}

.network-layer .network-segment,
.network-layer .net-dot{
  opacity: .12;
}

.network-layer.intro-done .network-segment{
  opacity: 1;
}

.network-layer.intro-done .net-dot{
  opacity: 1;
}

@keyframes introLogoSpinPulse{
  0%,100%{
    transform: scale(1) rotate(0deg);
    box-shadow:
      0 16px 36px rgba(21, 101, 214, .24),
      0 0 0 1px rgba(255,255,255,.04) inset;
  }
  50%{
    transform: scale(1.04) rotate(6deg);
    box-shadow:
      0 18px 42px rgba(21, 101, 214, .28),
      0 0 22px rgba(85, 176, 255, .12),
      0 0 0 1px rgba(255,255,255,.04) inset;
  }
}

@keyframes introLineIn{
  from{
    opacity: 0;
    transform: translateY(10px);
  }
  to{
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes introCenterFloat{
  from{ transform: translateY(-3px); }
  to{ transform: translateY(4px); }
}

@keyframes introFaceBlink{
  0%, 46%, 50%, 100% { }
  48% { }
}

.intro-face-ready .eye{
