  background:rgba(255,182,55,.10);
  border-color:rgba(255,182,55,.18);
}
.aviat-ping-badge.high,
.aviat-ping-badge.loss{
  color:#ffd8de;
  background:rgba(255,86,110,.10);
  border-color:rgba(255,86,110,.18);
}

.aviat-ping-dot{
  width:6px;
  height:6px;
  border-radius:999px;
  background:currentColor;
  box-shadow:0 0 10px currentColor;
}

.aviat-ping-sep{
  opacity:.45;
}

/* ===== CARDS ===== */
.aviat-card-grid{
  display:grid;
  grid-template-columns:repeat(3, minmax(0,1fr));
  gap:14px;
}

.aviat-card-clean{
  position:relative;
  overflow:hidden;
  border-radius:20px;
  border:1px solid rgba(86,132,210,.16);
  background:
    radial-gradient(circle at 100% 0%, rgba(44,129,255,.08), transparent 28%),
    linear-gradient(180deg, rgba(7,13,27,.98), rgba(4,9,18,.96));
  padding:16px;
  box-shadow:
    0 18px 40px rgba(0,0,0,.26),
    inset 0 1px 0 rgba(255,255,255,.04);
  display:grid;
  gap:12px;
  transition:
    transform .25s ease,
    box-shadow .25s ease,
    border-color .25s ease;
}

.aviat-card-clean:hover{
  transform:translateY(-3px);
  box-shadow:
    0 24px 48px rgba(0,0,0,.34),
    0 0 0 1px rgba(120,180,255,.08),
    inset 0 1px 0 rgba(255,255,255,.05);
}

.aviat-card-clean::before{
  content:"";
  position:absolute;
  inset:0 auto 0 0;
  width:4px;
  background:linear-gradient(180deg, #29d7ff, #287bff);
  opacity:.9;
}

.aviat-card-clean.medium{
  border-color:rgba(255,188,74,.22);
}
.aviat-card-clean.medium::before{
  background:linear-gradient(180deg, #ffb020, #ffd56a);
}

.aviat-card-clean.high{
  border-color:rgba(255,108,142,.24);
}
.aviat-card-clean.high::before{
  background:linear-gradient(180deg, #ff5c7c, #ff9ab0);
}

.aviat-card-head{
  display:flex;
  justify-content:space-between;
  gap:10px;
  align-items:flex-start;
}

.aviat-card-badges{
  display:grid;
  gap:6px;
  justify-items:end;
}

.aviat-card-kicker{
  color:#73ddff;
  font-size:10px;
  font-weight:900;
  letter-spacing:.18em;
  text-transform:uppercase;
  margin-bottom:6px;
}

.aviat-card-title{
  font-size:20px;
  font-weight:1000;
  line-height:1.02;
  color:#f4f9ff;
}

.aviat-card-sub{
  margin-top:6px;
  color:#8ea5c8;
  font-size:12px;
}

.aviat-card-total{
  font-size:34px;
  line-height:1;
  font-weight:1000;
  letter-spacing:-.03em;
  color:#ffffff;
}

.aviat-card-total-label{
  margin-top:-4px;
  color:#7f98bf;
  font-size:10px;
  font-weight:900;
  letter-spacing:.16em;
  text-transform:uppercase;
}

.aviat-card-metrics{
  display:grid;
  grid-template-columns:repeat(2, minmax(0,1fr));
  gap:10px;
}

.aviat-card-metrics > div{
  min-height:52px;
  border-radius:14px;
  border:1px solid rgba(90,130,200,.10);
  background:rgba(255,255,255,.025);
  padding:9px 10px;
  display:grid;
  gap:5px;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.03);
}

.aviat-card-metrics span{
  color:#8098be;
  font-size:10px;
  font-weight:900;
  letter-spacing:.14em;
  text-transform:uppercase;
}

.aviat-card-metrics strong{
  font-size:16px;
  line-height:1.1;
  font-weight:1000;
  color:#f1f7ff;
}

.aviat-card-bar-shell{
  width:100%;
  height:10px;
  border-radius:999px;
  overflow:hidden;
  background:rgba(255,255,255,.05);
  border:1px solid rgba(90,130,200,.08);
  box-shadow:inset 0 2px 5px rgba(0,0,0,.18);
}

.aviat-card-bar{
  height:100%;
  border-radius:999px;
  transition:width .45s ease;
  background:linear-gradient(90deg, #206eff, #00d9ff);
  box-shadow:0 0 18px rgba(0,217,255,.22);
}
.aviat-card-bar.medium{
  background:linear-gradient(90deg, #ffb020, #ffd56a);
  box-shadow:0 0 18px rgba(255,181,65,.18);
}
.aviat-card-bar.high{
  background:linear-gradient(90deg, #ff5074, #ff94ac);
  box-shadow:0 0 18px rgba(255,96,130,.18);
}

/* ===== FOOTER PILLS ===== */
.aviat-bottom-mini{
  display:flex;
  flex-wrap:wrap;
  gap:10px;
}

.aviat-pill{
  min-height:30px;
  padding:0 12px;
  border-radius:999px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  font-size:10px;
  font-weight:900;
  letter-spacing:.10em;
  text-transform:uppercase;
  box-shadow:inset 0 1px 0 rgba(255,255,255,.03);
}

.aviat-pill.soft{
  color:#dce8ff;
  background:rgba(255,255,255,.03);
  border:1px solid rgba(90,130,200,.10);
}
.aviat-pill.ok{
  color:#dbfff3;
  background:rgba(44,255,143,.11);
  border:1px solid rgba(44,255,143,.18);
}
.aviat-pill.warn,
.aviat-pill.medium{
  color:#fff1d7;
  background:rgba(255,170,45,.11);
  border:1px solid rgba(255,170,45,.18);
}
.aviat-pill.crit,
.aviat-pill.high{
  color:#ffd8de;
  background:rgba(255,86,110,.11);
  border:1px solid rgba(255,86,110,.18);
}
.aviat-pill.normal{
  color:#d8ebff;
  background:rgba(89,166,255,.11);
  border:1px solid rgba(89,166,255,.18);
}

/* ===== RESPONSIVE ===== */
@media (max-width: 1280px){
  .aviat-card-grid{
    grid-template-columns:1fr;
  }
}

@media (max-width: 1080px){
  .aviat-clean-master{
    flex-direction:column;
  }

  .aviat-clean-master-right{
    width:100%;
    grid-template-columns:repeat(3, minmax(0,1fr));
  }
}

@media (max-width: 920px){
  .aviat-topology-canvas{
    min-height:620px;
    padding-top:72px;
  }

  .aviat-node-box.internet{
    top:20px;
  }

  .aviat-node-box.radio{
    top:140px;
  }

  .aviat-node-box.edge-a{
    left:50%;
    transform:translateX(-50%);
    bottom:170px;
  }

  .aviat-node-box.edge-b{
    left:50%;
    right:auto;
    transform:translateX(-50%);
    bottom:28px;
  }

  .aviat-flow-left{
    left:50%;
    top:236px;
    width:4px;
    height:88px;
    transform:translateX(-50%);
  }

  .aviat-flow-right{
    left:50%;
    right:auto;
    top:372px;
    width:4px;
    height:88px;
    transform:translateX(-50%);
  }

  .aviat-flow-left::before,
  .aviat-flow-right::before{
    background:linear-gradient(180deg, transparent, rgba(137,214,255,.95), transparent);
  }
}

@media (max-width: 760px){
  .aviat-clean-big{
    font-size:24px;
  }

  .aviat-clean-master-right{
    grid-template-columns:1fr;
  }

  .aviat-master-box{
    min-width:unset;
  }

  .aviat-node-box{
    min-width:unset;
    width:calc(100% - 28px);
  }

  .aviat-card-metrics{
    grid-template-columns:1fr;
  }

  .aviat-card-total{
    font-size:28px;
  }

  .aviat-legend{
    position:static;
    margin-bottom:10px;
    width:max-content;
  }
}
/* AVIAT-CLEAN-REBUILD-END */

.aviat-x-page{padding:20px}
.aviat-x-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
.aviat-x-card{background:#0b1a33;border-radius:16px;padding:16px;border:1px solid #1c3d6e}
.aviat-x-card-title{font-size:18px;font-weight:700}
.aviat-x-total{font-size:26px;font-weight:900}


