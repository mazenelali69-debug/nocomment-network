:root{
  font-family: Inter, Arial, Helvetica, sans-serif;
  color: #eaf2ff;
  color-scheme: dark;
  --sidebar-width: 290px;
  --bg-1: #020816;
  --bg-2: #04142d;
  --bg-3: #061b3f;
  --line: rgba(170, 210, 255, 0.16);
  --line-strong: rgba(195, 227, 255, 0.28);
  --text-soft: #9fb3d1;
  --panel-border: rgba(111, 155, 255, 0.13);
}

*{ box-sizing: border-box; }

html, body, #root{
  margin: 0;
  width: 100%;
  min-height: 100%;
}

body{
  min-height: 100vh;
  overflow-x: hidden;
  background:
    radial-gradient(circle at 16% 18%, rgba(24,72,175,.34), transparent 22%),
    radial-gradient(circle at 78% 16%, rgba(0,220,255,.10), transparent 20%),
    linear-gradient(90deg, var(--bg-1) 0%, #04112a 36%, #071a3a 70%, #031122 100%);
}

a{
  color: inherit;
  text-decoration: none;
}

button, input{
  font: inherit;
}

.app-shell{
  min-height: 100vh;
}

.sidebar{
  position: fixed;
  top: 0;
  left: 0;
  width: var(--sidebar-width);
  height: 100vh;
  padding: 22px;
  background: linear-gradient(180deg, rgba(5,15,33,.97), rgba(2,9,22,.96));
  border-right: 1px solid rgba(95, 140, 255, .12);
  backdrop-filter: blur(18px);
  display: flex;
  flex-direction: column;
  z-index: 30;
}

.app-main{
  margin-left: var(--sidebar-width);
  min-height: 100vh;
  padding: 12px;
}

.topbar{
  min-height: 56px;
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  border: 1px solid rgba(94, 148, 255, .12);
  border-radius: 16px;
  background: rgba(7, 19, 40, 0.32);
  backdrop-filter: blur(10px);
  box-shadow: 0 10px 24px rgba(0,0,0,.18);
}

.topbar-right-badge{
  margin-left: auto;
  min-height: 32px;
  padding: 0 10px;
  border-radius: 999px;
  display: flex;
  align-items: center;
  gap: 8px;
  border: 1px solid rgba(79, 177, 255, .12);
  background: rgba(5, 16, 35, .58);
  color: #dcecff;
  font-size: 11px;
  font-weight: 800;
}

.topbar-title{
  font-size: 15px;
  font-weight: 800;
  line-height: 1.05;
}

.topbar-subtitle{
  color: #97add0;
  font-size: 11px;
  margin-top: 2px;
}

.page-content{
  padding-top: 12px;
}

.brand-box{
  display: flex;
  align-items: center;
  gap: 12px;
}

.brand-mark{
  width: 48px;
  height: 48px;
  border-radius: 16px;
  display: grid;
  place-items: center;
  font-weight: 900;
  color: white;
  background: linear-gradient(135deg, #0f4fff, #00d2ff);
  box-shadow: 0 8px 24px rgba(38, 126, 255, .35);
}

.wifi-mark{
  font-size: 22px;
  background:
    radial-gradient(circle at 30% 30%, rgba(255,255,255,.22), transparent 35%),
    linear-gradient(135deg, #071f55, #0a3d92 55%, #0bb6d8);
  border: 1px solid rgba(96, 191, 255, .18);
}

.brand-title{
  font-size: 18px;
  font-weight: 800;
}

.brand-subtitle{
  color: #97add0;
  font-size: 12px;
  margin-top: 2px;
}

.nav-list{
  display: flex;
  flex-direction: column;
  gap: 10px;
  margin-top: 28px;
}

.nav-link{
  min-height: 52px;
  display: flex;
  align-items: center;
  padding: 0 16px;
  border: 1px solid rgba(122, 162, 255, .06);
  border-radius: 16px;
  color: #c9dbff;
  background: rgba(255,255,255,.015);
  transition: .2s ease;
}

.nav-link:hover{
  transform: translateY(-1px);
  border-color: rgba(99, 175, 255, .22);
  background: rgba(77, 163, 255, .07);
}

.nav-link.active{
  color: white;
  border-color: rgba(88, 181, 255, .28);
  background: linear-gradient(135deg, rgba(31, 106, 255, .18), rgba(0, 214, 255, .11));
  box-shadow: inset 0 0 0 1px rgba(120, 185, 255, .06);
}

.sidebar-footer{
  margin-top: auto;
  min-height: 54px;
  border-radius: 16px;
  border: 1px solid rgba(95, 141, 255, .12);
  background: rgba(255,255,255,.025);
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 0 14px;
  color: #d5e8ff;
}

.status-dot,
.status-live-dot{
  width: 10px;
  height: 10px;
  border-radius: 999px;
  background: #2cff8f;
  box-shadow: 0 0 14px rgba(44,255,143,.55);
  flex: 0 0 auto;
}

.mobile-menu-btn{
  display: none;
  width: 42px;
  height: 42px;
  border: 1px solid rgba(111, 155, 255, 0.13);
  border-radius: 12px;
  background: rgba(255,255,255,.04);
  color: white;
  cursor: pointer;
}

.page-header{
  margin-bottom: 22px;
}

.eyebrow{
  color: #66e3ff;
  font-size: 12px;
  letter-spacing: .18em;
  font-weight: 800;
  margin-bottom: 10px;
}

.page-title{
  margin: 0;
  font-size: clamp(28px, 4vw, 42px);
  line-height: 1.05;
  font-weight: 900;
}

.page-text,
.panel-text,
.stat-sub,
.hero-text{
  color: #9fb3d1;
  line-height: 1.7;
}

.card-grid{
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 18px;
}

.stat-card,
.panel,
.hero-panel{
  border: 1px solid rgba(98, 145, 255, .14);
  background: linear-gradient(180deg, rgba(7, 18, 39, .78), rgba(4, 12, 28, .74));
  box-shadow: 0 24px 70px rgba(0,0,0,.28);
  backdrop-filter: blur(14px);
}

.stat-card{
  border-radius: 24px;
  padding: 22px;
}

.stat-label{
  color: #66e3ff;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: .14em;
}

.stat-value{
  font-size: 28px;
  font-weight: 900;
  margin: 12px 0 10px;
}

.panel{
  margin-top: 18px;
  border-radius: 24px;
  padding: 24px;
}

.hero-panel{
  min-height: 180px;
  border-radius: 28px;
  padding: 28px;
  display: flex;
  justify-content: space-between;
  gap: 20px;
  align-items: center;
  margin-bottom: 18px;
}

.hero-kicker{
  color: #66e3ff;
  font-size: 12px;
  font-weight: 800;
  letter-spacing: .18em;
  margin-bottom: 10px;
}

.hero-title{
  font-size: clamp(28px, 4vw, 40px);
  font-weight: 900;
  line-height: 1.08;
  margin-bottom: 10px;
}

.hero-badge{
  min-width: 120px;
  min-height: 120px;
  border-radius: 24px;
  display: grid;
  place-items: center;
  font-size: 20px;
  font-weight: 900;
  color: #dffcff;
  background:
    radial-gradient(circle at 30% 30%, rgba(255,255,255,.08), transparent 40%),
    linear-gradient(135deg, rgba(17,83,211,.9), rgba(0,197,255,.65));
  box-shadow: 0 20px 40px rgba(0,0,0,.24);
}

.login-v3-screen{
  position: relative;
  min-height: 100vh;
  overflow: hidden;
  display: grid;
  place-items: center;
  padding: 24px;
}

.network-layer{
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.network-svg{
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.network-segment{
  stroke: var(--line);
  stroke-width: 0.12;
  animation: linePulse 7s ease-in-out infinite;
}

.net-dot{
  position: absolute;
  width: 3px;
  height: 3px;
  border-radius: 999px;
  background: rgba(190, 221, 255, .52);
  box-shadow: 0 0 8px rgba(180, 219, 255, .18);
  animation: dotTwinkle 5s ease-in-out infinite;
}

.net-dot.strong{
  width: 4px;
  height: 4px;
  background: rgba(215, 236, 255, .75);
  box-shadow: 0 0 12px rgba(210, 234, 255, .24);
}

.login-v3-header-left{
  position: absolute;
  top: 22px;
  left: 22px;
  z-index: 3;
}

.login-v3-header-right{
  position: absolute;
  top: 22px;
  right: 22px;
  z-index: 3;
}

.v3-brand{
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 8px 14px 8px 8px;
  border-radius: 18px;
  background: rgba(5, 16, 35, .42);
  border: 1px solid rgba(96, 160, 255, .12);
  backdrop-filter: blur(12px);
}

.v3-brand-icon{
  width: 40px;
  height: 40px;
  border-radius: 14px;
  display: grid;
  place-items: center;
  background:
    radial-gradient(circle at 30% 30%, rgba(255,255,255,.22), transparent 36%),
    linear-gradient(135deg, #0c2f72, #1359c1 58%, #18cbff);
  box-shadow: 0 10px 22px rgba(21, 101, 214, .22);
}

.v3-brand-ring{
  width: 16px;
  height: 16px;
  border: 2px solid rgba(255,255,255,.95);
  border-radius: 999px;
  display: block;
  box-shadow: 0 0 10px rgba(255,255,255,.18);
}

.v3-brand-title{
  font-size: 18px;
  font-weight: 900;
  letter-spacing: -.02em;
}

.v3-brand-subtitle{
  font-size: 12px;
  color: #99aed1;
  margin-top: 2px;
}

.v3-status-pill{
  min-height: 40px;
  padding: 0 14px;
  border-radius: 999px;
  display: flex;
  align-items: center;
  gap: 10px;
  color: #edf5ff;
  background: rgba(4, 15, 33, .48);
  border: 1px solid rgba(96, 160, 255, .12);
  backdrop-filter: blur(10px);
  box-shadow: 0 10px 24px rgba(0,0,0,.18);
  white-space: nowrap;
}

.v3-live-dot{
  width: 10px;
  height: 10px;
  border-radius: 999px;
  background: #32f59a;
  box-shadow: 0 0 14px rgba(50,245,154,.5);
}

.v3-sep{
  width: 1px;
  height: 14px;
  background: rgba(255,255,255,.14);
}

.login-card-parallax-wrap{
  position: relative;
  z-index: 3;
  width: 100%;
  max-width: 420px;
}

.login-v3-card{
  position: relative;
  width: 100%;
  border-radius: 26px;
  padding: 30px 28px 22px;
  background: linear-gradient(180deg, rgba(4, 12, 29, .78), rgba(3, 10, 24, .92));
  border: 1px solid rgba(100, 145, 255, .13);
  box-shadow:
    0 28px 90px rgba(0,0,0,.34),
    inset 0 1px 0 rgba(255,255,255,.02);
  backdrop-filter: blur(16px);
  transform-style: preserve-3d;
  transition: transform .16s ease-out, box-shadow .16s ease-out;
  --mx: 50%;
  --my: 50%;
}

.card-mouse-glow{
  position: absolute;
  inset: 0;
  border-radius: inherit;
  pointer-events: none;
  background:
    radial-gradient(circle at var(--mx) var(--my), rgba(95,170,255,.18), transparent 22%);
  mix-blend-mode: screen;
}

.login-v3-card h1,
.v3-subtitle,
.v3-form,
.v3-footer,
.v3-build{
  position: relative;
  z-index: 2;
}

.login-v3-card h1{
  margin: 0;
  font-size: clamp(34px, 5vw, 44px);
  line-height: 1.02;
  font-weight: 900;
  letter-spacing: -.03em;
}

.v3-subtitle{
  margin: 10px 0 0;
  color: #a5b9d8;
  font-size: 13px;
  font-weight: 600;
}

.v3-form{
  display: grid;
  gap: 10px;
  margin-top: 18px;
}

.v3-label{
  font-size: 13px;
  color: #e2edff;
  font-weight: 700;
  margin-top: 6px;
}

.v3-input{
  width: 100%;
  min-height: 48px;
  border-radius: 14px;
  border: 1px solid rgba(113, 156, 255, .11);
  background: rgba(255,255,255,.035);
  color: #ffffff;
  padding: 0 14px;
  outline: none;
  transition: .18s ease;
}

.v3-input::placeholder{
  color: #8095b5;
}

.v3-input:focus{
  border-color: rgba(79, 175, 255, .42);
  box-shadow: 0 0 0 4px rgba(58, 140, 255, .09);
}

.v3-password-wrap{
  position: relative;
}

.v3-password-wrap .v3-input{
  padding-right: 54px;
}

.v3-eye-btn{
  position: absolute;
  top: 50%;
  right: 8px;
  transform: translateY(-50%);
  width: 36px;
  height: 36px;
  border-radius: 12px;
  border: 1px solid rgba(255,255,255,.07);
  background: rgba(255,255,255,.03);
  color: #cfddf5;
  cursor: pointer;
}

.v3-login-btn{
  margin-top: 8px;
  min-height: 48px;
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 800;
  font-size: 15px;
  background: linear-gradient(180deg, #1550b0, #15469b);
  border: 1px solid rgba(79, 160, 255, .2);
  color: white;
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,.06),
    0 10px 20px rgba(9, 47, 114, .16);
}

.v3-footer{
  margin-top: 18px;
  text-align: center;
  font-size: 11px;
  color: #a1b3d0;
  font-weight: 600;
}

.v3-build{
  width: fit-content;
  margin: 10px auto 0;
  min-height: 26px;
  padding: 0 10px;
  border-radius: 999px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,.04);
  border: 1px solid rgba(255,255,255,.06);
  color: #e3edff;
  font-size: 12px;
  font-weight: 800;
}

.mobile-overlay{
  display: none;
}

@keyframes linePulse{
  0%,100%{ opacity: .38; stroke: var(--line); }
  50%{ opacity: .95; stroke: var(--line-strong); }
}

}

@keyframes dotTwinkle{
  0%,100%{ opacity: .28; transform: scale(1); }
  50%{ opacity: .88; transform: scale(1.45); }
}

}

@media (max-width: 1100px){
  .card-grid{
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media (max-width: 860px){
  .mobile-menu-btn{
    display: inline-grid;
    place-items: center;
  }

  .sidebar{
    transform: translateX(-100%);
    transition: transform .25s ease;
  }

  .sidebar.mobile-open{
    transform: translateX(0);
  }

  .mobile-overlay{
    display: block;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.45);
    opacity: 0;
    pointer-events: none;
    transition: .25s ease;
    z-index: 20;
  }

  .mobile-overlay.show{
    opacity: 1;
    pointer-events: auto;
  }

  .app-main{
  margin-left: var(--sidebar-width);
  min-height: 100vh;
  padding: 12px;
}

  .topbar{
  min-height: 56px;
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 10px 14px;
  border: 1px solid rgba(94, 148, 255, .12);
  border-radius: 16px;
  background: rgba(7, 19, 40, 0.32);
  backdrop-filter: blur(10px);
  box-shadow: 0 10px 24px rgba(0,0,0,.18);
}

  .topbar-right-badge{
  margin-left: auto;
  min-height: 32px;
  padding: 0 10px;
  border-radius: 999px;
  display: flex;
  align-items: center;
  gap: 8px;
  border: 1px solid rgba(79, 177, 255, .12);
  background: rgba(5, 16, 35, .58);
  color: #dcecff;
  font-size: 11px;
  font-weight: 800;
}

  .login-v3-screen{
    align-content: start;
    padding-top: 18px;
  }

  .login-v3-header-left,
  .login-v3-header-right{
    position: static;
    width: 100%;
    max-width: 420px;
  }

  .login-v3-header-left{
    margin-bottom: 12px;
  }

  .login-v3-header-right{
    margin-bottom: 14px;
  }

  .v3-status-pill{
    width: 100%;
    justify-content: flex-start;
    overflow: hidden;
    font-size: 12px;
  }

  .card-grid{
    grid-template-columns: 1fr;
  }

  .hero-panel{
    flex-direction: column;
    align-items: flex-start;
  }
}

@media (max-width: 560px){
  .login-v3-card{
    padding: 24px 18px 18px;
    border-radius: 22px;
  }

  .login-v3-card h1{
    font-size: 32px;
  }

  .v3-brand-title{
    font-size: 16px;
  }

  .v3-brand-subtitle{
    font-size: 11px;
  }

  .v3-status-pill{
    gap: 8px;
  }

  .page-title,
  .hero-title{
    font-size: 28px;
  }

  .stat-card,
  .panel,
  .hero-panel{
    border-radius: 20px;
    padding: 18px;
  }
}

.drift-a{
  animation: networkDriftA 7s ease-in-out infinite alternate;
}

.drift-b{
  animation: networkDriftB 8s ease-in-out infinite alternate;
}

.drift-c{
  animation: networkDriftC 7.5s ease-in-out infinite alternate;
}

@keyframes networkDriftA{
  0%   { transform: translate3d(0px,0px,0px); }
  50%  { transform: translate3d(10px,-8px,0px); }
  100% { transform: translate3d(-8px,10px,0px); }
}

@keyframes networkDriftB{
  0%   { transform: translate3d(0px,0px,0px); }
  50%  { transform: translate3d(-12px,6px,0px); }
  100% { transform: translate3d(8px,-10px,0px); }
}

@keyframes networkDriftC{
  0%   { transform: translate3d(0px,0px,0px); }
  50%  { transform: translate3d(14px,8px,0px); }
  100% { transform: translate3d(-10px,-6px,0px); }
}

.face-widget{
  position: relative;
  z-index: 2;
  width: 100%;
  display: grid;
  place-items: center;
  margin-bottom: 12px;
}

.face-head{
  position: relative;
  width: 68px;
  height: 68px;
  border-radius: 999px;
  background:
    radial-gradient(circle at 32% 26%, rgba(255,255,255,.16), transparent 34%),
    linear-gradient(180deg, rgba(24,92,205,.96), rgba(10,50,118,.96));
  border: 1px solid rgba(116, 173, 255, .18);
  box-shadow:
    0 12px 28px rgba(0,0,0,.24),
    inset 0 1px 0 rgba(255,255,255,.05);
  transition: transform .22s ease, box-shadow .22s ease, filter .22s ease;
}

.face-eyes{
  position: absolute;
  top: 24px;
  left: 0;
  width: 100%;
  display: flex;
  justify-content: center;
  gap: 14px;
  transition: transform .18s ease;
}

.eye{
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: #edf6ff;
  box-shadow: 0 0 6px rgba(255,255,255,.12);
  transition: transform .18s ease, width .18s ease, height .18s ease, border-radius .18s ease;
}

.face-mouth{
  position: absolute;
  left: 50%;
  top: 42px;
  width: 18px;
  height: 8px;
  transform: translateX(-50%);
  border-bottom: 2px solid #edf6ff;
  border-radius: 0 0 16px 16px;
  transition: all .2s ease;
}

.face-blush{
  position: absolute;
  top: 39px;
  width: 9px;
  height: 6px;
  border-radius: 999px;
  background: rgba(255, 135, 170, .12);
  opacity: 0;
  transition: opacity .2s ease;
}

.face-blush.left{ left: 12px; }
.face-blush.right{ right: 12px; }

.face-status{
  margin-top: 8px;
  font-size: 11px;
  color: #93a9cc;
  font-weight: 700;
  letter-spacing: .02em;
}

.face-hand{
  position: absolute;
  right: 30%;
  top: 12px;
  font-size: 18px;
  opacity: 0;
  transform: translateY(6px) rotate(-14deg);
  transition: all .28s ease;
  pointer-events: none;
}

.face-widget.look-user .face-eyes{
  position: absolute;
  top: 24px;
  left: 0;
  width: 100%;
  display: flex;
  justify-content: center;
  gap: 14px;
  transition: transform .18s ease;
}

.face-widget.look-pass .face-eyes{
  position: absolute;
  top: 24px;
  left: 0;
  width: 100%;
  display: flex;
  justify-content: center;
  gap: 14px;
  transition: transform .18s ease;
}

.face-widget.typing-user .face-head{
  position: relative;
  width: 68px;
  height: 68px;
  border-radius: 999px;
  background:
    radial-gradient(circle at 32% 26%, rgba(255,255,255,.16), transparent 34%),
    linear-gradient(180deg, rgba(24,92,205,.96), rgba(10,50,118,.96));
  border: 1px solid rgba(116, 173, 255, .18);
  box-shadow:
    0 12px 28px rgba(0,0,0,.24),
    inset 0 1px 0 rgba(255,255,255,.05);
  transition: transform .22s ease, box-shadow .22s ease, filter .22s ease;
}

.face-widget.typing-pass .eye{
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: #edf6ff;
  box-shadow: 0 0 6px rgba(255,255,255,.12);
  transition: transform .18s ease, width .18s ease, height .18s ease, border-radius .18s ease;
}

.face-widget.sad .face-head{
  position: relative;
  width: 68px;
  height: 68px;
  border-radius: 999px;
  background:
    radial-gradient(circle at 32% 26%, rgba(255,255,255,.16), transparent 34%),
    linear-gradient(180deg, rgba(24,92,205,.96), rgba(10,50,118,.96));
  border: 1px solid rgba(116, 173, 255, .18);
  box-shadow:
    0 12px 28px rgba(0,0,0,.24),
    inset 0 1px 0 rgba(255,255,255,.05);
  transition: transform .22s ease, box-shadow .22s ease, filter .22s ease;
}

.face-widget.sad .face-mouth{
  border-bottom: 0;
  border-top: 2px solid #edf6ff;
  border-radius: 16px 16px 0 0;
  top: 47px;
}

.face-widget.sad .eye{
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: #edf6ff;
  box-shadow: 0 0 6px rgba(255,255,255,.12);
  transition: transform .18s ease, width .18s ease, height .18s ease, border-radius .18s ease;
}

.face-widget.happy .face-mouth,
.face-widget.success .face-mouth{
  width: 22px;
  height: 10px;
  border-bottom-width: 3px;
  border-radius: 0 0 18px 18px;
}

.face-widget.happy .face-blush,
.face-widget.success .face-blush{
  position: absolute;
  top: 39px;
  width: 9px;
  height: 6px;
  border-radius: 999px;
  background: rgba(255, 135, 170, .12);
  opacity: 0;
  transition: opacity .2s ease;
}

.face-widget.success .face-head{
  transform: translateY(-1px) scale(1.02);
  box-shadow:
    0 16px 34px rgba(0,0,0,.26),
    0 0 18px rgba(50,245,154,.10),
    inset 0 1px 0 rgba(255,255,255,.05);
}

.face-widget.success .face-hand{
  position: absolute;
  right: 30%;
  top: 12px;
  font-size: 18px;
  opacity: 0;
  transform: translateY(6px) rotate(-14deg);
  transition: all .28s ease;
  pointer-events: none;
}

.v3-error{
  min-height: 40px;
  border-radius: 12px;
  padding: 10px 12px;
  background: rgba(255, 71, 102, .08);
  border: 1px solid rgba(255, 91, 122, .18);
  color: #ffb8c4;
  font-size: 13px;
  font-weight: 700;
}

.v3-demo-note{
  margin-top: 14px;
  text-align: center;
  font-size: 12px;
  color: #8ea7ca;
  font-weight: 700;
}

.drift-a{
  animation: networkDriftA 7s ease-in-out infinite alternate;
}

.drift-b{
  animation: networkDriftB 8s ease-in-out infinite alternate;
}

.drift-c{
  animation: networkDriftC 7.5s ease-in-out infinite alternate;
}

@keyframes networkDriftA{
  0%   { transform: translate3d(0px,0px,0px); }
  50%  { transform: translate3d(16px,-10px,0px); }
  100% { transform: translate3d(-12px,14px,0px); }
}

@keyframes networkDriftB{
  0%   { transform: translate3d(0px,0px,0px); }
  50%  { transform: translate3d(-18px,8px,0px); }
  100% { transform: translate3d(10px,-14px,0px); }
}

@keyframes networkDriftC{
  0%   { transform: translate3d(0px,0px,0px); }
  50%  { transform: translate3d(18px,10px,0px); }
  100% { transform: translate3d(-12px,-8px,0px); }
}

.intro-overlay{
