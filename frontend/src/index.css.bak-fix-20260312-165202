.intro-line.l1{ animation: introLineIn .45s ease forwards .15s; }
.intro-line.l2{ animation: introLineIn .45s ease forwards .55s; }
.intro-line.l3{ animation: introLineIn .45s ease forwards .95s; }

.intro-corner-hide{
  opacity: 0;
  transform: translateY(-10px);
  pointer-events: none;
}

.intro-corner-show{
  opacity: 1;
  transform: translateY(0);
  transition: opacity .5s ease 2.1s, transform .5s ease 2.1s;
}

.intro-card-hidden{
  opacity: 0;
  transform: translateY(30px) scale(.96);
  pointer-events: none;
}

.intro-card-ready{
  opacity: 1;
  transform: translateY(0) scale(1);
  transition: opacity .65s ease 2s, transform .65s ease 2s;
}

.intro-face-hidden{
  opacity: 0;
  transform: translateY(8px) scale(.96);
}

.intro-face-ready{
  opacity: 1;
  transform: translateY(0) scale(1);
