    mood === "happy" ? "happy" : "",
    mood === "success" ? "success" : "",
    usernameFocused ? "look-user" : "",
    passwordFocused ? "look-pass" : "",
    isTypingUser ? "typing-user" : "",
    isTypingPass ? "typing-pass" : "",
    introDone ? "intro-face-ready" : "intro-face-hidden",
