import React, { useEffect, useMemo, useState } from "react"

const API_URL = "/api/aviat/status"
const HISTORY_LIMIT = 24

function toNum(v, fallback = 0) {
  const n = Number(v)
  return Number.isFinite(n) ? n : fallback
}

function fmtMbps(v) {
  return Number.isFinite(v) ? `${v.toFixed(2)} Mbps` : "--"
}

function fmtPct(v) {
  return Number.isFinite(v) ? `${v.toFixed(1)}%` : "--"
}

function fmtMs(v) {
  return Number.isFinite(v) ? `${v} ms` : "--"
}

function sev(util) {
  if (!Number.isFinite(util)) return "normal"
  if (util >= 85) return "high"
  if (util >= 60) return "medium"
  return "normal"
}

function sevLabel(util) {
  if (!Number.isFinite(util)) return "Normal"
  if (util >= 85) return "Critical"
  if (util >= 60) return "Warning"
  return "Normal"
}

function pingTone(ok, latency) {
  if (!ok || !Number.isFinite(latency)) return "high"
  if (latency >= 80) return "high"
  if (latency >= 40) return "medium"
  return "ok"
}

function pushHistory(prev, key, value) {
  const current = Array.isArray(prev[key]) ? prev[key] : []
  const next = [...current, toNum(value, 0)].slice(-HISTORY_LIMIT)
  return { ...prev, [key]: next }
}

function Badge({ children, tone = "normal" }) {
  return <span className={`aviat-tf-badge ${tone}`}>{children}</span>
}

function ProgressBar({ value, tone }) {
  const safe = Math.max(0, Math.min(100, toNum(value, 0)))
  return (
    <div className="aviat-tf-progress">
      <div className={`aviat-tf-progress-bar ${tone}`} style={{ width: `${safe}%` }} />
    </div>
  )
}

function Sparkline({ values = [], tone = "normal" }) {
  const width = 320
  const height = 68
  const padding = 6
  const vals = values.length ? values : [0, 0, 0, 0, 0, 0]
  const min = Math.min(...vals)
  const max = Math.max(...vals)
  const range = Math.max(1, max - min)

  const points = vals.map((v, i) => {
    const x = padding + (i * (width - padding * 2)) / Math.max(1, vals.length - 1)
    const y = height - padding - ((v - min) / range) * (height - padding * 2)
    return [x, y]
  })

  const d = points.map((p, i) => `${i === 0 ? "M" : "L"} ${p[0]} ${p[1]}`).join(" ")

  return (
    <div className="aviat-tf-spark-wrap">
      <svg viewBox={`0 0 ${width} ${height}`} preserveAspectRatio="none" className="aviat-tf-spark">
        <defs>
          <linearGradient id={`grad-${tone}`} x1="0" y1="0" x2="1" y2="0">
            <stop offset="0%" stopColor={tone === "high" ? "#fb7185" : tone === "medium" ? "#f59e0b" : "#38bdf8"} />
            <stop offset="100%" stopColor={tone === "high" ? "#ef4444" : tone === "medium" ? "#fbbf24" : "#22c55e"} />
          </linearGradient>
        </defs>
        <path d={d} className="aviat-tf-spark-line" stroke={`url(#grad-${tone})`} />
      </svg>
    </div>
  )
}

function MiniStat({ label, value }) {
  return (
    <div className="aviat-tf-mini-stat">
      <span>{label}</span>
      <strong>{value}</strong>
    </div>
  )
}

function TrafficCard({ title, sub, item, ping, history }) {
  const tone = sev(item.utilizationPct)
  const pTone = pingTone(ping.lastOk, ping.lastLatencyMs)

  return (
    <section className={`aviat-tf-card ${tone}`}>
      <div className="aviat-tf-card-top">
        <div>
          <div className="aviat-tf-kicker">Traffic Interface</div>
          <h3>{title}</h3>
          <div className="aviat-tf-sub">{sub}</div>
        </div>

        <div className="aviat-tf-badge-stack">
          <Badge tone={item.status === "ONLINE" ? "ok" : "medium"}>{item.status || "UNKNOWN"}</Badge>
          <Badge tone={tone}>{sevLabel(item.utilizationPct)}</Badge>
        </div>
      </div>

      <div className="aviat-tf-big-number">{fmtMbps(item.totalMbps)}</div>
      <div className="aviat-tf-big-label">Current Throughput</div>

      <Sparkline values={history} tone={tone} />

      <div className="aviat-tf-grid">
        <MiniStat label="RX" value={fmtMbps(item.rxMbps)} />
        <MiniStat label="TX" value={fmtMbps(item.txMbps)} />
        <MiniStat label="Capacity" value={Number.isFinite(item.capacityMbps) ? `${item.capacityMbps} Mbps` : "--"} />
        <MiniStat label="Ping" value={ping.lastOk ? fmtMs(ping.lastLatencyMs) : "Loss"} />
      </div>

      <div className="aviat-tf-util-row">
        <span>Utilization</span>
        <strong>{fmtPct(item.utilizationPct)}</strong>
      </div>

      <ProgressBar value={item.utilizationPct} tone={tone} />

      <div className="aviat-tf-footer">
        <Badge tone={pTone}>{ping.lastOk ? `Ping ${fmtMs(ping.lastLatencyMs)}` : "No Reply"}</Badge>
        <Badge tone={ping.lastOk ? "ok" : "high"}>{ping.lastOk ? "Reachable" : "Loss"}</Badge>
      </div>
    </section>
  )
}

function PingCard({ title, item }) {
  const tone = pingTone(item.lastOk, item.lastLatencyMs)

  return (
    <div className="aviat-tf-ping-card">
      <div>
        <div className="aviat-tf-kicker">Ping Target</div>
        <div className="aviat-tf-ping-title">{title}</div>
        <div className="aviat-tf-sub">{item.ip || "--"}</div>
      </div>
      <div className="aviat-tf-ping-right">
        <div className="aviat-tf-ping-value">{item.lastOk ? fmtMs(item.lastLatencyMs) : "Loss"}</div>
        <Badge tone={tone}>{item.lastOk ? "Online" : "Loss"}</Badge>
      </div>
    </div>
  )
}

