    let alive = true

    async function load() {
      try {
        const res = await fetch(API_URL, { cache: "no-store" })
        if (!res.ok) throw new Error(`HTTP ${res.status}`)

        const data = await res.json()
        if (!alive) return

        setPayload(data)
        setError("")

        const cards = data?.cards || {}
        setHistory((prev) => {
          let next = prev
          next = pushHistory(next, "uplink", cards?.uplink?.totalMbps)
          next = pushHistory(next, "switchA", cards?.switchA?.totalMbps)
          next = pushHistory(next, "switchB", cards?.switchB?.totalMbps)
          return next
        })
      } catch (e) {
        if (!alive) return
        setError(e?.message || "Request failed")
      } finally {
        if (alive) setLoading(false)
      }
    }

    load()
    const timer = setInterval(load, 3000)

    return () => {
      alive = false
      clearInterval(timer)
    }
