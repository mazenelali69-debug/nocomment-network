        totalMbps: n(uplink.totalMbps, 0),
        utilizationPct: n(uplink.utilizationPct, 0),
        capacityMbps: n(uplink.capacityMbps, 3000),
        status: uplink.status || "UNKNOWN",
      },
      switchA: {
        label: switchA.label || "Switch A",
        ifName: switchA.ifName || "TenGigE1/2",
        rxMbps: n(switchA.rxMbps, 0),
        txMbps: n(switchA.txMbps, 0),
        totalMbps: n(switchA.totalMbps, 0),
        utilizationPct: n(switchA.utilizationPct, 0),
        capacityMbps: n(switchA.capacityMbps, 1000),
        status: switchA.status || "UNKNOWN",
      },
      switchB: {
        label: switchB.label || "Switch B",
        ifName: switchB.ifName || "TenGigE1/1",
        rxMbps: n(switchB.rxMbps, 0),
        txMbps: n(switchB.txMbps, 0),
        totalMbps: n(switchB.totalMbps, 0),
        utilizationPct: n(switchB.utilizationPct, 0),
        capacityMbps: n(switchB.capacityMbps, 1000),
        status: switchB.status || "UNKNOWN",
      },
      ping: {
        thgv: ping.thgv || {},
        aviat: ping.aviat || {},
        edgeA: ping.edgeA || {},
        edgeB: ping.edgeB || {},
      },
    }
  }, [payload])

  const peakUtil = Math.max(
    data.uplink.utilizationPct || 0,
    data.switchA.utilizationPct || 0,
    data.switchB.utilizationPct || 0
  )

  const totalTraffic = data.uplink.totalMbps || 0
  const headerTone = sev(peakUtil)

  return (
    <main className="aviatv2-page">
      <style>{`
