import React, { useEffect, useMemo, useState } from "react"

const API_URL = "/api/aviat/status"

function n(v, fallback = null) {
  const x = Number(v)
  return Number.isFinite(x) ? x : fallback
}

function fmtMbps(v) {
  return Number.isFinite(v) ? `${v.toFixed(2)} Mbps` : "--"
}

function fmtPct(v) {
  return Number.isFinite(v) ? `${v.toFixed(1)}%` : "--"
}

function fmtMs(v) {
  return Number.isFinite(v) ? `${v} ms` : "--"
}

function sev(util) {
  if (!Number.isFinite(util)) return "normal"
  if (util >= 85) return "high"
  if (util >= 60) return "medium"
  return "normal"
}

function sevLabel(util) {
  if (!Number.isFinite(util)) return "Normal"
  if (util >= 85) return "Critical"
  if (util >= 60) return "Warning"
  return "Normal"
}

function pingState(ok, latency) {
  if (ok === false || !Number.isFinite(latency)) return "loss"
  if (latency >= 80) return "high"
  if (latency >= 40) return "medium"
  return "normal"
}

function Badge({ children, tone = "normal" }) {
  return <span className={`aviatv2-badge aviatv2-badge-${tone}`}>{children}</span>
}

function StatBox({ label, value, sub }) {
  return (
    <div className="aviatv2-statbox">
      <div className="aviatv2-statbox-label">{label}</div>
      <div className="aviatv2-statbox-value">{value}</div>
      {sub ? <div className="aviatv2-statbox-sub">{sub}</div> : null}
    </div>
  )
}

function Progress({ value, tone }) {
  const safe = Math.max(0, Math.min(100, Number(value) || 0))
  return (
    <div className="aviatv2-progress">
      <div className={`aviatv2-progress-bar ${tone}`} style={{ width: `${safe}%` }} />
    </div>
  )
}

function InterfaceCard({ title, ifName, item, ping }) {
  const tone = sev(item.utilizationPct)
  const pingTone = pingState(ping.lastOk, ping.lastLatencyMs)

  return (
    <section className="aviatv2-card">
      <div className="aviatv2-card-head">
        <div>
          <div className="aviatv2-kicker">Interface</div>
          <h3>{title}</h3>
          <div className="aviatv2-muted">{ifName || "--"}</div>
        </div>

        <div className="aviatv2-badges">
          <Badge tone={item.status === "ONLINE" ? "ok" : "medium"}>{item.status || "UNKNOWN"}</Badge>
          <Badge tone={tone}>{sevLabel(item.utilizationPct)}</Badge>
        </div>
      </div>

      <div className="aviatv2-stats-grid">
        <StatBox label="RX" value={fmtMbps(item.rxMbps)} />
        <StatBox label="TX" value={fmtMbps(item.txMbps)} />
        <StatBox label="TOTAL" value={fmtMbps(item.totalMbps)} />
        <StatBox label="CAPACITY" value={Number.isFinite(item.capacityMbps) ? `${item.capacityMbps} Mbps` : "--"} />
      </div>

      <div className="aviatv2-util">
        <div className="aviatv2-util-row">
          <span>Utilization</span>
          <strong>{fmtPct(item.utilizationPct)}</strong>
        </div>
        <Progress value={item.utilizationPct} tone={tone} />
      </div>

      <div className="aviatv2-foot-row">
        <Badge tone={pingTone}>Ping {fmtMs(ping.lastLatencyMs)}</Badge>
        <Badge tone={ping.lastOk ? "ok" : "high"}>{ping.lastOk ? "Reachable" : "Loss"}</Badge>
      </div>
    </section>
  )
}

function PingCard({ title, item }) {
  const tone = pingState(item.lastOk, item.lastLatencyMs)

  return (
    <section className="aviatv2-ping-card">
      <div className="aviatv2-ping-top">
        <div>
          <div className="aviatv2-kicker">Ping Target</div>
          <h3>{title}</h3>
          <div className="aviatv2-muted">{item.ip || "--"}</div>
        </div>
        <Badge tone={tone}>{item.lastOk ? "Online" : "Loss"}</Badge>
      </div>

      <div className="aviatv2-ping-latency">
        {item.lastOk ? fmtMs(item.lastLatencyMs) : "No reply"}
      </div>
    </section>
  )
}

